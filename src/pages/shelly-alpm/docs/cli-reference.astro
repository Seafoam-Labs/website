---
import { getEntry, render } from "astro:content";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

const entry = await getEntry("remoteDocs", "shelly-cli-reference");

if (!entry || !entry.rendered) {
  throw new Error("Failed to load the CLI reference documentation.");
}

// Need to remove 'Overview' to avoid repeating in TOC using spliced
const { Content, headings } = await render(entry);
---

<StarlightPage
  frontmatter={{ title: entry.data.title }}
  headings={headings.toSpliced(1, 1)}
>
  <Content />
</StarlightPage>
