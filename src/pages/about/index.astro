---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { Image } from "astro:assets";
import zoeyerinbauer from "../../assets/images/team/zoeyerinbauer.webp";
import caroberrie from "../../assets/images/team/caroberrie.webp";
import vinnyqf from "../../assets/images/team/vinnyqf.jpg";
import azdanov from "../../assets/images/team/azdanov.webp";
import type { ImageMetadata } from "astro";

export interface TeamContact {
  label: string;
  text: string;
  url?: string;
}

export interface TeamMember {
  name: string;
  role: string;
  bio: string;
  imageSrc: ImageMetadata;
  imageAlt: string;
  contacts: TeamContact[];
}

export const teamMembers: TeamMember[] = [
  {
    name: "Zoey Erin Bauer",
    role: "Co-Founder",
    bio: ".Net Architect with a goal of making Linux more accessible for everyone.",
    imageSrc: zoeyerinbauer,
    imageAlt: "Zoey Erin Bauer's profile picture.",
    contacts: [
      {
        label: "Github",
        text: "ZoeyErinBauer",
        url: "https://github.com/ZoeyErinBauer",
      },
      {
        label: "Bluesky",
        text: "zoeyerinbauer.bsky.social",
        url: "https://bsky.app/profile/zoeyerinbauer.bsky.social",
      },
      { label: "Fluxer", text: "zoeybear#0000" },
    ],
  },
  {
    name: "Caroline Snyder",
    role: "Co-Founder",
    bio: "Trying to make the world a bit better. Software developer as day job. Coding as hobby from time to time.",
    imageSrc: caroberrie,
    imageAlt: "Caroline Snyder's profile picture.",
    contacts: [
      {
        label: "Github",
        text: "caroberrie",
        url: "https://github.com/caroberrie",
      },
      {
        label: "Bluesky",
        text: "caroberrie.bsky.social",
        url: "https://bsky.app/profile/caroberrie.bsky.social",
      },
      { label: "Fluxer", text: "caro#0001" },
    ],
  },
  {
    name: "Vinícius Fonseca",
    role: "Maintainer",
    bio: "Computer Engineering (CE) student and open source contributor.",
    imageSrc: vinnyqf,
    imageAlt: "Vinícius Fonseca's profile picture.",
    contacts: [
      { label: "Github", text: "VinnyQF", url: "https://github.com/VinnyQF" },
    ],
  },
  {
    name: "Anton Ždanov",
    role: "Maintainer",
    bio: "Just a Full Stack Developer who works with all sorts of technologies.",
    imageSrc: azdanov,
    imageAlt: "Anton Ždanov's profile picture.",
    contacts: [
      { label: "Github", text: "azdanov", url: "https://github.com/azdanov" },
      {
        label: "Website",
        text: "azdanov.dev",
        url: "https://www.azdanov.dev/",
      },
    ],
  },
];
---

<StarlightPage
  frontmatter={{
    title: "About",
    template: "splash",
    description:
      "Learn about Seafoam Labs - who we are, what we build, and the people behind the projects.",
  }}
  hasSidebar={false}
>
  <p>
    Seafoam Labs is a small team building <a href="/welcome#projects"
      >open-source tools</a
    > for Arch Linux and beyond. We care deeply about details such as performant code,
    good design, and making things that actually feel nice to use. We believe that
    the Linux desktop doesn't have to be intimidating; it can be approachable and
    genuinely enjoyable. Open-source software deserves the same care and polish as
    anything you'd pay for, and that's what we're here for.
  </p>

  <h2>Team</h2>

  <p>
    We're a small group of Linux enthusiasts building the tools we use
    ourselves-passionate people who genuinely love what we do and care about
    doing things right.
  </p>

  <ul
    role="list"
    class="mx-auto mt-10 grid max-w-2xl grid-cols-1 gap-x-14 gap-y-12 p-0 sm:grid-cols-2 lg:max-w-none"
  >
    {
      teamMembers.map((member) => (
        <li class="flex flex-col gap-4 xl:flex-row">
          <div class="w-52 flex-none">
            <Image
              src={member.imageSrc}
              alt={member.imageAlt}
              class="rounded-2xl"
              width={180}
              height={180}
              layout="fixed"
            />
          </div>
          <div class="m-0 flex-auto">
            <div>
              <h3 class="text-lg font-semibold text-(--sl-color-white)">
                {member.name}
              </h3>
              <p class="mt-0">{member.role}</p>
            </div>
            <p class="mt-4">{member.bio}</p>
            <p class="mt-4">
              {member.contacts.map((contact, index) => (
                <>
                  {contact.label}:{" "}
                  {contact.url ? (
                    <a href={contact.url}>{contact.text}</a>
                  ) : (
                    contact.text
                  )}
                  {index < member.contacts.length - 1 && <br />}
                </>
              ))}
            </p>
          </div>
        </li>
      ))
    }
  </ul>

  <h2>Contact</h2>
  <p>
    Have questions or want to reach out? You can contact us at <a
      href="mailto:developers@seafoamlabs.org">developers@seafoamlabs.org</a
    >.
  </p>
</StarlightPage>
