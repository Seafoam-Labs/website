---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import AnchorHeading from "@astrojs/starlight/components/AnchorHeading.astro";
import { Card, CardGrid, LinkCard } from "@astrojs/starlight/components";
import { Image } from "astro:assets";
import chel from "../assets/images/chel.png";
import jetbrainsWhite from "../assets/icons/jetbrains-white.svg";
---

<StarlightPage
  frontmatter={{
    title: "Welcome",
    description:
      "Open-source tools for Arch Linux and beyond - built with care by Seafoam Labs",
    template: "splash",
    hero: {
      title: "Seafoam Labs",
      tagline:
        "Open-source tools for Arch Linux and beyond - designed with you in mind.",
      image: {
        alt: "Cartoon character with teal twin pigtails, large expressive eyes, a white lab coat and pink heart shirt, smiling and waving with one hand while the other arm is outstretched to the left.",
        file: chel,
      },
      actions: [
        {
          text: "Learn more",
          link: "/welcome",
          variant: "primary",
        },
        {
          text: "Blog",
          link: "/blog",
          variant: "minimal",
        },
      ],
    },
  }}
  hasSidebar={false}
>
  <AnchorHeading level="2" id="projects">Projects</AnchorHeading>

  <CardGrid>
    <Card title="Shelly ALPM" icon="linux">
      A modern, visual package manager for Arch Linux - a Pacman alternative
      designed with you in mind. Built in C# with GTK4, Shelly ALPM brings a
      polished UI to Arch package management with support for CachyOS, Garuda
      Linux, and more.

      <p class="mt-3">
        <a href="/shelly-alpm">Explore Shelly ALPM →</a>
      </p>
    </Card>

    <Card title="Starfish" icon="star">
      A dependency viewer for Arch packages. Visualise and explore the
      dependency graph of any package installed on your system with clarity and
      ease.

      <p class="mt-3">
        <a href="/starfish/overview">Explore Starfish →</a>
      </p>
    </Card>

    <Card title="Aqueous" icon="seti:elixir">
      A new Seafoam Labs project - currently in early development. Stay tuned
      for updates.

      <p class="mt-3">
        <a href="/aqueous/overview">Explore Aqueous →</a>
      </p>
    </Card>
  </CardGrid>

  <AnchorHeading level="2" id="about-seafoam-labs"
    >About Seafoam Labs</AnchorHeading
  >

  <LinkCard
    title="GitHub Organisation"
    description="Browse all Seafoam Labs repositories on GitHub."
    href="https://github.com/Seafoam-Labs"
  />

  <LinkCard
    title="Seafoam Labs Arch Repository"
    description="Coming soon - browse our custom Arch Linux repository."
    href="#"
  />

  <AnchorHeading level="3" id="powered-by">Powered by</AnchorHeading>

  <div class="my-4">
    <a
      href="https://jb.gg/OpenSource"
      class="inline-block rounded-md p-3 hover:bg-(--sl-color-gray-6) dark:hover:bg-(--sl-color-gray-6)"
    >
      <Image
        src={jetbrainsWhite}
        class="hidden dark:block"
        alt="JetBrains logo."
        width={298}
        height={64}
      />
      <Image
        src="https://resources.jetbrains.com/storage/products/company/brand/logos/jetbrains.svg"
        class="mt-0 block dark:hidden"
        alt="JetBrains logo."
        width={298}
        height={64}
      />
    </a>
  </div>
</StarlightPage>
